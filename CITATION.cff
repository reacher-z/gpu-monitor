    name: "reacher-z"
repository-code: "https://github.com/reacher-z/gpu-monitor"
url: "https://github.com/reacher-z/gpu-monitor"
license: MIT
version: "0.3.0"
date-released: "2026-03-07"
keywords:
  - GPU monitoring
  - NVIDIA
  - machine learning
  - deep learning
  - Prometheus
  - notifications
  - Slack
  - Discord
  - Telegram
