# GPU Monitor configuration
# Copy this file to .env or export these variables before running.

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
CHECK_INTERVAL=60
IDLE_THRESHOLD=10
IDLE_MINUTES=5
ALERT_COOLDOWN=30
STATUS_ACTIVE=10
STATUS_IDLE=30
# MACHINE_COLOR=#2eb886
# LOG_FILE=gpu_monitor.log

# Proxy settings (if needed)
# http_proxy=http://your-proxy-host:port
# https_proxy=http://your-proxy-host:port
