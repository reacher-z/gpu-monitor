# GPU Monitor configuration
# Copy to .env or export these variables before running.

# ---- Notification Channels (configure one or more) ----

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=recipient@example.com

# SMS via Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+15550000000
TWILIO_TO=+15551234567

# iMessage (macOS only)
IMESSAGE_TO=+15551234567

# ---- General ----
CHECK_INTERVAL=60
IDLE_THRESHOLD=10
IDLE_MINUTES=5
ALERT_COOLDOWN=30
STATUS_ACTIVE=10
STATUS_IDLE=30
# MACHINE_COLOR=#2eb886
# LOG_FILE=gpu_monitor.log

# ---- Proxy (if needed) ----
# http_proxy=http://your-proxy-host:port
# https_proxy=http://your-proxy-host:port
