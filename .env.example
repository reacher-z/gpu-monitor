# GPU Monitor configuration
# Copy to .env or export these variables before running.

# ---- Notification Channels (configure one or more) ----

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=recipient@example.com

# SMS via Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+15550000000
TWILIO_TO=+15551234567

# iMessage (macOS only)
IMESSAGE_TO=+15551234567

# WeCom (企业微信) group bot
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# Feishu / Lark (飞书) bot
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN

# DingTalk (钉钉) group robot
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# Bark iOS push (https://github.com/Finb/Bark)
BARK_URL=https://api.day.app/YOUR_DEVICE_KEY

# ntfy (https://ntfy.sh) — zero-signup push notifications, self-hostable
NTFY_URL=https://ntfy.sh/your-topic
# NTFY_TOKEN=your-token  # optional, for protected topics

# Gotify (https://gotify.net) — self-hosted push notification server
GOTIFY_URL=http://gotify.example.com
GOTIFY_TOKEN=your-app-token

# Pushover (https://pushover.net) — iOS/Android push notifications
PUSHOVER_TOKEN=your-app-token
PUSHOVER_USER=your-user-key

# Microsoft Teams incoming webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/YOUR_WEBHOOK

# Mattermost incoming webhook
MATTERMOST_WEBHOOK_URL=https://your-mattermost.example.com/hooks/YOUR_TOKEN

# Rocket.Chat incoming webhook
ROCKETCHAT_WEBHOOK_URL=https://your-rocketchat.example.com/hooks/YOUR_TOKEN

# Google Chat space webhook
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY

# Zulip bot API
ZULIP_SITE=https://yourorg.zulipchat.com
ZULIP_EMAIL=bot@yourorg.zulipchat.com
ZULIP_API_KEY=your-api-key
# ZULIP_STREAM=general
# ZULIP_TOPIC=GPU Monitor

# Apprise (https://github.com/caronc/apprise) — optional, requires pip install apprise
# Supports 80+ services in one env var: slack://, tgram://, discord://, etc.
# APPRISE_URLS=slack://token/channel tgram://bot_token/chat_id

# OpenClaw (https://openclaw.ai) — routes to WhatsApp, Teams, Signal, LINE, Matrix, Mattermost, Zalo, and 20+ more
OPENCLAW_WEBHOOK_URL=http://your-openclaw-host:18789/hooks/wake
# OPENCLAW_WEBHOOK_SECRET=your-bearer-token  # optional

# ---- GitHub Pages Dashboard (optional) ----
# Push GPU stats to a GitHub repo so the static dashboard can read them.
# Create a fine-grained token with Contents read+write on your Pages repo.
GITHUB_PAGES_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_PAGES_REPO=your-username/your-repo

# ---- General ----
CHECK_INTERVAL=60
IDLE_THRESHOLD=10
IDLE_MINUTES=5
ALERT_COOLDOWN=30
STATUS_ACTIVE=10
STATUS_IDLE=30
# MACHINE_COLOR=#2eb886
# LOG_FILE=gpu_monitor.log
# WEB_PORT=8080
# GPU_TEMP_WARN=85
# GPU_TEMP_CRIT=92

# ---- Proxy (if needed) ----
# http_proxy=http://your-proxy-host:port
# https_proxy=http://your-proxy-host:port
